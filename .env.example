# ========================
# Server Configuration
# ========================
NODE_ENV=production
PORT=3001
BASE_URL=https://certificate-5-hixf.onrender.com

# ========================
# Main Backend & Auth
# ========================
MAIN_BACKEND_URL=https://your-main-backend-url.com
SERVICE_AUTH_TOKEN=your_service_auth_token_here

# ========================
# Database
# ========================
MONGODB_URI=mongodb://localhost:27017/certificates



# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# Storage
# ========================
STORAGE_TYPE=local

# ========================
# Cloudinary (REQUIRED for PDFs)
# ========================
CLOUDINARY_CLOUD_NAME=dnq998bc8
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========================
# JWT
# ========================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

# ========================
# Platform Branding
# ========================
PLATFORM_NAME=Learning Platform
PLATFORM_LOGO_URL=https://certificate-5-hixf.onrender.com/assets/logo.png
SIGNATURE_IMAGE_URL=

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# Batch Processing
# ========================
MAX_BATCH_SIZE=100
BATCH_TIMEOUT_MS=300000

# ========================
# Email (Optional)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password