# Copy to .env and fill values. Do not commit .env.

# Server
NODE_ENV=
PORT=
BASE_URL=https://certificate-5-hixf.onrender.com

# Database (use Atlas in production — not localhost)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/certificates

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Storage
STORAGE_TYPE=

# Cloudinary (all three required for uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=

# Platform
PLATFORM_NAME=
PLATFORM_LOGO_URL=

# Rate limiting
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=

# SMTP (optional mail)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
